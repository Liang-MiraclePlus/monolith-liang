        .hero h1 em {
            font-style: italic;
            font-weight: 400;
            color: var(--text-main);
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-light);
            max-width: 600px;
            margin-bottom: 32px;
            font-family: var(--font-serif);
            position: relative;
            z-index: 2;
        }

        .hero .link-group {
            width: 100%;
        }

        .hero .art-link {
            width: 100%;
        }

        /* 章节通用样式 */
        .section {
            padding: 56px 0;
            border-bottom: 1px solid var(--line-color);
