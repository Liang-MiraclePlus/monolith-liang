                radial-gradient(circle at 82% 46%, rgba(255, 255, 255, 0.58) 0 1.1px, transparent 1.3px),
                radial-gradient(circle at 96% 60%, rgba(255, 255, 255, 0.5) 0 1.1px, transparent 1.3px),
