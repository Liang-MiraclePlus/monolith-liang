        /* 顶部 Hero Section */
        .hero {
            min-height: 80vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            position: relative;
            padding-top: 72px;
            border-bottom: 1px solid var(--line-color);
            position: relative;
