    <style>
        :root {
            /* 提取自参考图的极简艺术配色 */
            --bg-color: #F8F9FA;
            /* 极浅的灰白底色 */
            --text-main: #2C3E50;
            /* 深灰蓝，比纯黑更柔和高级 */
            --text-light: #596A7A;
            --accent-blue: #1A3B66;
            /* 核心点缀蓝 (类似参考图的刷色) */
            --line-color: #D1D8E0;

            /* 字体栈 */
            --font-serif: 'Playfair Display', 'Noto Serif SC', 'Songti SC', serif;
            --font-sans: 'Inter', -apple-system, 'PingFang SC', sans-serif;
            --paper-base: #f2f1ee;
            --paper-ink: #e3e0d9;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #f4f4f2;
            color: var(--text-main);
            font-family: var(--font-sans);
            line-height: 1.8;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            position: relative;
            isolation: isolate;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            z-index: -2;
            background:
                radial-gradient(1400px 700px at 18% 24%, rgba(255, 255, 255, 0.97), rgba(244, 244, 241, 0.72) 66%, rgba(235, 233, 228, 0.64) 100%),
