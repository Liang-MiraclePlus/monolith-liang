        #portfolio-content {
            position: relative;
        }

        #portfolio-content::before {
            content: '';
            position: absolute;
            left: 50%;
            top: 180px;
            transform: translateX(-50%);
            width: 86%;
            height: 520px;
            pointer-events: none;
            z-index: 0;
            opacity: 0.26;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 960 520' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cfilter id='soft'%3E%3CfeGaussianBlur stdDeviation='1.8'/%3E%3C/filter%3E%3C/filter id='subtle'%3E%3CfeGaussianBlur stdDeviation='0.8'/%3E%3C/filter%3E%3C/defs%3E%3Cpath d='M60 190 C 180 88, 308 300, 430 188 C 550 84, 680 292, 806 182' stroke='%23e3e2dd' stroke-width='72' fill='none' stroke-linecap='round' filter='url(%23soft)' opacity='0.65'/%3E%3Cpath d='M64 188 C 186 86, 312 298, 434 186 C 554 82, 686 290, 812 180' stroke='%23faf9f7' stroke-width='24' fill='none' stroke-linecap='round' filter='url(%23subtle)' opacity='0.86'/%3E%3C/svg%3E") no-repeat center/contain;
