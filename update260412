            display: inline-block;
            width: 40px;
            height: 2px;
            background-color: var(--accent-blue);
            margin-right: 15px;
        }

        .section-title::after {
            content: '';
            position: absolute;
            left: 52px;
            bottom: -6px;
            width: 180px;
            height: 10px;
            background: linear-gradient(90deg, rgba(30, 67, 122, 0.18), rgba(30, 67, 122, 0.04));
            filter: blur(0.4px);
            border-radius: 999px;
            pointer-events: none;
        }

        /* 理念与定位 */
        .philosophy-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 18px;
        }

        .philosophy-card {
            padding-left: 20px;
            border-left: 1px solid var(--line-color);
        }

        .philosophy-card h3 {
            font-family: var(--font-serif);
            font-size: 1.4rem;
            margin-bottom: 15px;
            color: var(--text-main);
        }

        .philosophy-card p {
            font-size: 0.95rem;
            color: var(--text-light);
        }

        /* 核心案例 */
        .case-item {
            margin-bottom: 44px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 14px;
            align-items: start;
        }

        .case-content {
            display: flex;
            flex-direction: column;
        }

        /* 纯文字案例布局：不展示图片 */

        .case-header {
            margin-bottom: 16px;
        }

        .case-role {
            font-size: 0.9rem;
            color: var(--accent-blue);
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 600;
            display: block;
            margin-bottom: 10px;
        }

        .case-header h3 {
            font-family: var(--font-serif);
            font-size: 1.8rem;
            color: var(--text-main);
            margin-bottom: 15px;
        }

        .case-points {
            list-style: none;
            margin-bottom: 16px;
        }

        .case-points li {
            margin-bottom: 12px;
            padding-left: 15px;
            position: relative;
            color: var(--text-light);
            font-size: 0.95rem;
        }

        .case-points li::before {
            content: '·';
            color: var(--accent-blue);
            position: absolute;
            left: 0;
            top: 0;
            font-weight: bold;
        }

        .case-points strong {
            color: var(--text-main);
            font-weight: 600;
        }

        /* 链接卡片 (替代原来的大按钮) */
        .link-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 10px;
        }

        .art-link {
            display: inline-flex;
            align-items: center;
            padding: 15px 20px;
            background: #fff;
            border: 1px solid var(--line-color);
            text-decoration: none;
            color: var(--text-main);
            font-size: 0.95rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        }

        .art-link:hover {
            border-color: var(--accent-blue);
            transform: translateX(5px);
            box-shadow: 0 8px 20px rgba(26, 59, 102, 0.08);
        }

        .art-link span.tag {
            background: var(--bg-color);
            color: var(--text-light);
            font-size: 0.75rem;
            padding: 2px 8px;
            margin-right: 15px;
            border: 1px solid var(--line-color);
        }

        .platform-icon {
            width: 16px;
            height: 16px;
            margin-right: 10px;
            object-fit: contain;
            flex-shrink: 0;
            align-self: center;
        }

        .art-link strong {
            font-weight: 600;
            margin-right: 10px;
        }

        .art-link i {
            margin-left: auto;
            color: var(--accent-blue);
            font-style: normal;
            font-family: var(--font-serif);
        }

        .art-note {
            cursor: default;
            opacity: 0.9;
        }

        .art-note:hover {
            border-color: var(--line-color);
            transform: none;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        }

        footer {
            padding: 36px 0;
            text-align: center;
            color: var(--text-light);
            font-size: 0.85rem;
            letter-spacing: 1px;
            font-family: var(--font-serif);
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.8rem;
            }

            .container {
                padding: 0 20px;
            }

            .case-item {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            body::after {
                top: 42vh;
                height: 20px;
            }
        }
    </style>
</head>

