        .hero-subtitle {
            font-size: 0.85rem;
            letter-spacing: 6px;
            text-transform: uppercase;
            color: #1a2e57;
            margin-bottom: 14px;
            font-family: var(--font-sans);
            font-weight: 600;
        }

        .hero h1 {
            font-family: var(--font-serif);
            font-size: 4rem;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 20px;
            color: #111d4d;
            text-shadow: 0 1px 0 rgba(255, 255, 255, 0.8);
