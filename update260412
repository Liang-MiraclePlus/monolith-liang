                url("data:image/svg+xml,%3Csvg viewBox='0 0 480 480' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Cfilter id='soft'%3E%3CfeGaussianBlur stdDeviation='0.9'/%3E%3C/filter%3E%3C/defs%3E%3Crect width='100%25' height='100%25' fill='%23f4f4f2'/%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.045'/%3E%3Cpath d='M-30 120 C 76 30, 184 220, 290 114 C 368 36, 446 178, 520 86' stroke='%23e2e2de' stroke-width='28' fill='none' stroke-linecap='round' filter='url(%23soft)' opacity='0.78'/%3E%3Cpath d='M-24 116 C 82 26, 190 214, 294 110 C 372 34, 450 172, 526 82' stroke='%23f8f8f6' stroke-width='14' fill='none' stroke-linecap='round' opacity='0.82'/%3E%3Cpath d='M-26 292 C 70 214, 178 392, 286 304 C 370 236, 454 350, 522 276' stroke='%23e4e3de' stroke-width='24' fill='none' stroke-linecap='round' filter='url(%23soft)' opacity='0.72'/%3E%3Cpath d='M-20 288 C 76 210, 182 386, 290 300 C 374 234, 456 346, 526 272' stroke='%23f8f8f6' stroke-width='12' fill='none' stroke-linecap='round' opacity='0.78'/%3E%3C/svg%3E");
            background-size: cover, cover, 620px 620px;
        }

        body::after {
            content: '';
            position: fixed;
            left: -6%;
            top: 52vh;
            width: 112%;
            height: 42px;
            transform: rotate(-1.5deg);
            z-index: -1;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0) 46%),
                radial-gradient(circle at 10% 38%, rgba(255, 255, 255, 0.62) 0 1.1px, transparent 1.2px),
                radial-gradient(circle at 28% 64%, rgba(255, 255, 255, 0.52) 0 1.2px, transparent 1.4px),
